# ==============================================================
# Payam Production Environment Variables
# ==============================================================
# Place this file as /opt/payam/.env on the Node
# Secure it with: chmod 600 /opt/payam/.env
#
# Create acme.json before first run:
#   touch /opt/payam/traefik/acme.json && chmod 600 /opt/payam/traefik/acme.json
# ==============================================================

# --- Application Image ---
# GHCR image tag published by the CI/CD pipeline
APP_IMAGE=ghcr.io/your-org/javatemplate:sha-abc1234

# --- Domain & TLS ---
# Production domain used by Traefik for routing and Let's Encrypt certificate
DOMAIN=api.example.com

# Email address for Let's Encrypt expiry notifications
LETSENCRYPT_EMAIL=admin@example.com

# --- PostgreSQL ---
POSTGRES_DB=payam
POSTGRES_USER=payam
# Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=change-me-use-openssl-rand

# Spring Boot datasource — uses Docker service name 'postgres'
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/${POSTGRES_DB}?TimeZone=UTC

# --- Security ---
# JWT signing secret — generate with: openssl rand -base64 64
JWT_SECRET=change-me-use-openssl-rand

# --- Email / SMTP ---
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=noreply@example.com
SPRING_MAIL_PASSWORD=change-me

# --- Bunny.net CDN (Video Storage) ---
BUNNY_API_KEY=change-me
BUNNY_LIBRARY_ID=123456
BUNNY_CDN_HOSTNAME=your-library.b-cdn.net

# --- LGTM Observability Stack ---
MONITORING_DOMAIN=monitoring.api.example.com
GF_SECURITY_ADMIN_USER=admin
# Generate with: openssl rand -base64 24
GF_SECURITY_ADMIN_PASSWORD=change-me-use-openssl-rand
LOKI_URL=http://loki:3100
LOKI_ENABLED=true
MANAGEMENT_OTLP_TRACING_ENDPOINT=http://tempo:4318/v1/traces

# --- Grafana Alert Notifications ---
# SMTP server for Grafana to send email alerts (separate from Spring Boot's SPRING_MAIL_* vars)
# GF_SMTP_HOST format: hostname:port (e.g. smtp.gmail.com:587 for STARTTLS)
GF_SMTP_ENABLED=true
GF_SMTP_HOST=smtp.example.com:587
GF_SMTP_USER=alerts@example.com
# App password or SMTP credential (same provider as SPRING_MAIL_* if using the same server)
GF_SMTP_PASSWORD=change-me
GF_SMTP_FROM_ADDRESS=alerts@example.com
GF_SMTP_FROM_NAME=Payam Alerts
# MandatoryStartTLS | OpportunisticStartTLS | NoStartTLS
GF_SMTP_STARTTLS_POLICY=MandatoryStartTLS
# Email address that receives all Grafana alerts (can be same as LETSENCRYPT_EMAIL)
GF_ALERT_NOTIFY_EMAIL=admin@example.com
# Slack incoming webhook URL for Grafana alert notifications
# Slack → Apps → Incoming Webhooks → Add to Slack → select #alerts channel → copy URL
GF_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# --- Backup: Hetzner Object Storage ---
# Hetzner Object Storage credentials (S3-compatible)
# Create a bucket in Hetzner Cloud Console → Object Storage
HOS_ACCESS_KEY=change-me
HOS_SECRET_KEY=change-me
# Bucket name (no protocol prefix)
HOS_BUCKET=payam-backups
# Region endpoint — find in Hetzner Object Storage console (e.g. fsn1, nbg1, hel1)
HOS_ENDPOINT=https://s3.fsn1.hetzner.com
# Key prefix in the bucket — trailing slash required
HOS_BACKUP_PREFIX=pg-backups/

# --- Backup: Hetzner Cloud API ---
# API token for creating volume snapshots (read/write scope required)
HCLOUD_TOKEN=change-me
# Numeric ID of the Hetzner Volume attached to this Node
# Find in Hetzner Cloud Console → Volumes → click the volume → copy the ID from the URL
HETZNER_VOLUME_ID=12345678
