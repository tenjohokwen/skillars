+          </q-step>
+
+          <q-step :name="2" :title="t('auth.coach.step2Title')" icon="sports_soccer" :done="store.lastCompletedStep >= 2">
+            <ProfileBuilderStep2 :loading="store.loading" @submit="onStep2" />
